{
  "expo": {
    "name": "Hair Tryon",
    "slug": "hair-tryon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "main": "expo-router/entry",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#231014"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hairtryon.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#231014"
      },
      "package": "com.hairtryon.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF5C8A"
        }
      ],
      "expo-web-browser"
    ],
    "scheme": "hairtryon"
  }
}
